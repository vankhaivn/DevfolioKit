---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import ThemeToggle from '@/components/ui/ThemeToggle.tsx';
import LayoutToggle from '@/components/ui/LayoutToggle.tsx';
import ResumeButton from '@/components/ui/ResumeButton.astro';
import Icon from '@/components/ui/Icon.astro';
import type { IconName } from '@/lib/icons.js';
import { SOCIAL_ICON_NAMES } from '@/lib/icons.js';
import type { Config } from '@/lib/schema.js';

interface Props {
  config: Config;
}

const { config } = Astro.props;
const { profile, resume } = config;
const social = config.social?.filter((s) => s.enabled !== false);

// Detect whether a physical resume file exists in public/
// If yes → download mode. If no → print/export mode (always show the button).
const resumePublicPath = (resume?.path ?? '/resume.pdf').replace(/^\//, '');
const hasResumeFile = existsSync(join(process.cwd(), 'public', resumePublicPath));
const resumeMode = hasResumeFile ? 'download' : 'print';
const resumeLabel = resume?.label ?? undefined; // undefined → ResumeButton uses its default
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-identity">
      <h1 class="header-name">{profile.name}</h1>
      <p class="header-headline">{profile.headline}</p>
      {profile.location && (
        <p class="header-location">
          <Icon name="map-pin" size={12} />
          {profile.location}
        </p>
      )}
    </div>

    <div class="header-actions">
      {social && social.length > 0 && (
        <nav class="header-social" aria-label="Social links">
          {social.map((link) => {
            const platform = link.platform.toLowerCase() as IconName;
            const isKnown = SOCIAL_ICON_NAMES.includes(platform);
            return (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label ?? link.platform}
                class="social-link"
              >
                {isKnown ? (
                  <Icon name={platform} size={16} />
                ) : (
                  <span class="social-text">{link.label ?? link.platform}</span>
                )}
              </a>
            );
          })}
        </nav>
      )}

      <ThemeToggle client:load />
      <LayoutToggle client:load />

      <ResumeButton
        mode={resumeMode}
        path={hasResumeFile ? (resume?.path ?? '/resume.pdf') : undefined}
        label={resumeLabel}
      />
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
    padding-block: 2rem;
  }

  .header-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .header-name {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .header-headline {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .header-location {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .header-social {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--color-text-muted);
    transition: color 0.15s, background-color 0.15s;
    text-decoration: none;
  }

  .social-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface);
    text-decoration: none;
  }

  .social-text {
    font-size: 0.75rem;
    font-weight: 500;
  }
</style>
