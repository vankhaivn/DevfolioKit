---
import Icon from '@/components/ui/Icon.astro';

interface Props {
  mode: 'download' | 'print';
  path?: string;
  label?: string;
}

const { mode, path, label = mode === 'download' ? 'Download Resume' : 'Export as PDF' } = Astro.props;
---

{mode === 'download' ? (
  <a
    href={path}
    download
    class="resume-btn"
    aria-label={label}
  >
    <Icon name="download" size={14} />
    {label}
  </a>
) : (
  <button
    class="resume-btn"
    aria-label={label}
    onclick="window.print()"
  >
    <Icon name="printer" size={14} />
    {label}
  </button>
)}

<style>
  .resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #ffffff;
    border: 1px solid var(--color-accent);
    border-radius: 0.375rem;
    background-color: var(--color-accent);
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
    white-space: nowrap;
    font-family: inherit;
  }

  .resume-btn:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    text-decoration: none;
    color: #ffffff;
  }
</style>
