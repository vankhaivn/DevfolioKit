---
import type { WorkExperience } from '@/lib/schema.js';

interface Props {
  experience: WorkExperience[];
}

const { experience } = Astro.props;

function formatDate(dateStr: string): string {
  const [year, month] = dateStr.split('-');
  if (!month) return year ?? dateStr;
  const d = new Date(parseInt(year ?? '0'), parseInt(month ?? '0') - 1);
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

{experience.length > 0 && (
  <section class="section" id="experience" aria-labelledby="experience-heading">
    <h2 class="section-title" id="experience-heading">Experience</h2>

    <div class="timeline">
      {experience.map((job) => (
        <article class="timeline-item">
          <div class="timeline-dot" aria-hidden="true"></div>

          <div class="job-header">
            <div class="job-meta">
              <h3 class="job-role">
                {job.role}
                <span class="job-at"> @ </span>
                <span class="job-company">{job.company}</span>
              </h3>
              {job.location && (
                <span class="job-location">{job.location}</span>
              )}
            </div>
            <div class="job-dates" aria-label={`${formatDate(job.start)} to ${job.end ? formatDate(job.end) : 'Present'}`}>
              <time datetime={job.start}>{formatDate(job.start)}</time>
              <span aria-hidden="true"> – </span>
              {job.end ? (
                <time datetime={job.end}>{formatDate(job.end)}</time>
              ) : (
                <span class="job-current">Present</span>
              )}
            </div>
          </div>

          {job.summary && (
            <p class="job-summary">{job.summary}</p>
          )}

          {job.highlights && job.highlights.length > 0 && (
            <ul class="job-highlights">
              {job.highlights.map((h) => (
                <li>
                  <span class="highlight-bullet" aria-hidden="true">▹</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .timeline {
    position: relative;
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    position: relative;
  }

  .timeline-dot {
    position: absolute;
    width: 0.75rem;
    height: 0.75rem;
    background-color: var(--color-accent);
    border-radius: 50%;
    left: calc(-1.5rem - 7px);
    top: 0.375rem;
    border: 3px solid var(--color-bg);
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .job-role {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.2rem;
    line-height: 1.4;
  }

  .job-at {
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .job-company {
    color: var(--color-accent);
  }

  .job-location {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
    margin-top: 0.125rem;
  }

  .job-dates {
    font-size: 0.8125rem;
    font-family: ui-monospace, monospace;
    color: var(--color-text-subtle);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job-current {
    color: var(--color-accent);
    font-weight: 500;
  }

  .job-summary {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.65;
  }

  .job-highlights {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .job-highlights li {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .highlight-bullet {
    color: var(--color-accent);
    flex-shrink: 0;
    line-height: 1.6;
  }
</style>
