---
import type { SkillGroup } from '@/lib/schema.js';

interface Props {
  skills: SkillGroup[];
}

const { skills } = Astro.props;
---

{skills.length > 0 && (
  <section class="section" id="skills" aria-labelledby="skills-heading">
    <h2 class="section-title" id="skills-heading">Skills</h2>

    <div class="skills-groups">
      {skills.map((group) => (
        <div class="skill-group">
          <h3 class="skill-category">{group.category}</h3>
          <div class="skill-tags">
            {group.items.map((item) => (
              <span class="tag">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .skills-groups {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-group {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .skill-category {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    min-width: 7rem;
    flex-shrink: 0;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    flex: 1;
  }
</style>
