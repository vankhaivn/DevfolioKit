---
import type { Project } from '@/lib/schema.js';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  projects: Project[];
  variant?: 'list' | 'grid';
}

const { projects, variant = 'list' } = Astro.props;
---

{projects.length > 0 && (
  <section class="section" id="projects" aria-labelledby="projects-heading">
    <h2 class="section-title" id="projects-heading">Projects</h2>

    <div class={variant === 'grid' ? 'projects-grid' : 'projects-list'}>
      {projects.map((project) => (
        <article class="project-card">
          <div class="project-header">
            <h3 class="project-name">
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a>
              ) : project.name}
            </h3>
            <div class="project-links">
              {project.url && (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link" aria-label={`${project.name} live site`}>
                  <Icon name="external-link" size={13} />
                </a>
              )}
              {project.repo && (
                <a href={project.repo} target="_blank" rel="noopener noreferrer" class="project-link" aria-label={`${project.name} repository`}>
                  <Icon name="github" size={13} />
                </a>
              )}
            </div>
          </div>

          <p class="project-description">{project.description}</p>

          {project.highlights && project.highlights.length > 0 && (
            <ul class="project-highlights">
              {project.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          )}

          {project.tags && project.tags.length > 0 && (
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .projects-list .project-card {
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: none;
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
  }

  .projects-list .project-card:first-child {
    padding-top: 0;
  }

  .projects-list .project-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .projects-grid .project-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .projects-grid .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 28px -6px rgba(0, 0, 0, 0.12), 0 4px 8px -2px rgba(0, 0, 0, 0.06);
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .project-name a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .project-name a:hover {
    color: var(--color-accent);
  }

  .project-links {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.25rem;
    color: var(--color-text-muted);
    background: var(--color-surface-hover);
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
  }

  .project-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    text-decoration: none;
  }

  .project-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .project-highlights {
    margin: 0 0 0.5rem;
    padding-left: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-highlights li {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }
</style>
