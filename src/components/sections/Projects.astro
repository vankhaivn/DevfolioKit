---
import type { Project } from '@/lib/schema.js';

interface Props {
  projects: Project[];
  variant?: 'list' | 'grid';
}

const { projects, variant = 'list' } = Astro.props;
---

{projects.length > 0 && (
  <section class="section" id="projects" aria-labelledby="projects-heading">
    <h2 class="section-title" id="projects-heading">Projects</h2>

    <div class={variant === 'grid' ? 'projects-grid' : 'projects-list'}>
      {projects.map((project) => (
        <article class="project-card">
          <div class="project-header">
            <h3 class="project-name">
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a>
              ) : project.name}
            </h3>
            <div class="project-links">
              {project.url && (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link" aria-label={`${project.name} live site`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </a>
              )}
              {project.repo && (
                <a href={project.repo} target="_blank" rel="noopener noreferrer" class="project-link" aria-label={`${project.name} repository`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                  </svg>
                </a>
              )}
            </div>
          </div>

          <p class="project-description">{project.description}</p>

          {project.highlights && project.highlights.length > 0 && (
            <ul class="project-highlights">
              {project.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          )}

          {project.tags && project.tags.length > 0 && (
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .projects-list .project-card {
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: none;
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
  }

  .projects-list .project-card:first-child {
    padding-top: 0;
  }

  .projects-list .project-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .projects-grid .project-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .projects-grid .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 28px -6px rgba(0, 0, 0, 0.12), 0 4px 8px -2px rgba(0, 0, 0, 0.06);
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .project-name a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .project-name a:hover {
    color: var(--color-accent);
  }

  .project-links {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.25rem;
    color: var(--color-text-muted);
    background: var(--color-surface-hover);
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
  }

  .project-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    text-decoration: none;
  }

  .project-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .project-highlights {
    margin: 0 0 0.5rem;
    padding-left: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-highlights li {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }
</style>
