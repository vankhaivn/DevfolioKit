---
import type { Config } from '@/lib/schema.js';

interface Props {
  config: Config;
}

const { config } = Astro.props;
const { profile, social } = config;

const contactSocialIcons: Record<string, string> = {
  github: 'M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z',
  linkedin: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  twitter: 'M23.953 4.57a10 10 0 0 1-2.825.775 4.958 4.958 0 0 0 2.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 0 0-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 0 0-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 0 1-2.228-.616v.06a4.923 4.923 0 0 0 3.946 4.827 4.996 4.996 0 0 1-2.212.085 4.936 4.936 0 0 0 4.604 3.417 9.867 9.867 0 0 1-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 0 0 7.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0 0 24 4.59z',
};
---

<section class="section about-section" id="about" aria-labelledby="about-heading">
  <h2 class="section-title" id="about-heading">About</h2>

  <div class="about-content">
    {profile.avatar && (
      <div class="about-avatar-wrap">
        <img
          src={profile.avatar}
          alt={`${profile.name} profile photo`}
          class="about-avatar"
          width="80"
          height="80"
          loading="eager"
          onerror="this.style.display='none'"
        />
      </div>
    )}

    <div class="about-text">
      <p class="about-summary">{profile.summary}</p>

      <div class="about-meta">
        {profile.email && (
          <a href={`mailto:${profile.email}`} class="about-contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            {profile.email}
          </a>
        )}

        {social && social.map((link) => {
          const icon = contactSocialIcons[link.platform.toLowerCase()];
          return (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="about-contact-item"
              aria-label={link.label ?? link.platform}
            >
              {icon ? (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={icon} />
                </svg>
              ) : null}
              {link.label ?? link.platform}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-top: 2.5rem;
  }

  .about-content {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .about-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border);
    flex-shrink: 0;
  }

  .about-text {
    flex: 1;
  }

  .about-summary {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    white-space: pre-line;
    margin-bottom: 1rem;
  }

  .about-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .about-contact-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .about-contact-item:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
