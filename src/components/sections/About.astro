---
import type { Config } from '@/lib/schema.js';
import Icon from '@/components/ui/Icon.astro';
import type { IconName } from '@/lib/icons.js';
import { SOCIAL_ICON_NAMES } from '@/lib/icons.js';

interface Props {
  config: Config;
  variant?: 'default' | 'engineer';
}

const { config, variant = 'default' } = Astro.props;
const { profile } = config;
const social = config.social?.filter((s) => s.enabled !== false);
---

<section class="section about-section" id="about" aria-labelledby="about-heading">
  <h2 class="section-title" id="about-heading">About</h2>

  {variant === 'engineer' ? (
    <div class="about-content about-content--engineer">
      <div class="about-top">
        {profile.avatar && (
          <img
            src={profile.avatar}
            alt={`${profile.name} profile photo`}
            class="about-avatar"
            width="80"
            height="80"
            loading="eager"
            onerror="this.style.display='none'"
          />
        )}
        <div class="about-meta">
          {profile.email && (
            <a href={`mailto:${profile.email}`} class="about-contact-item">
              <Icon name="mail" size={14} />
              {profile.email}
            </a>
          )}
          {social && social.map((link) => {
            const platform = link.platform.toLowerCase() as IconName;
            const isKnown = SOCIAL_ICON_NAMES.includes(platform);
            return (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="about-contact-item"
                aria-label={link.label ?? link.platform}
              >
                {isKnown && <Icon name={platform} size={14} />}
                {link.label ?? link.platform}
              </a>
            );
          })}
        </div>
      </div>
      <p class="about-summary">{profile.summary}</p>
    </div>
  ) : (
    <div class="about-content">
      {profile.avatar && (
        <div class="about-avatar-wrap">
          <img
            src={profile.avatar}
            alt={`${profile.name} profile photo`}
            class="about-avatar"
            width="80"
            height="80"
            loading="eager"
            onerror="this.style.display='none'"
          />
        </div>
      )}

      <div class="about-text">
        <p class="about-summary">{profile.summary}</p>

        <div class="about-meta">
          {profile.email && (
            <a href={`mailto:${profile.email}`} class="about-contact-item">
              <Icon name="mail" size={14} />
              {profile.email}
            </a>
          )}

          {social && social.map((link) => {
            const platform = link.platform.toLowerCase() as IconName;
            const isKnown = SOCIAL_ICON_NAMES.includes(platform);
            return (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="about-contact-item"
                aria-label={link.label ?? link.platform}
              >
                {isKnown && <Icon name={platform} size={14} />}
                {link.label ?? link.platform}
              </a>
            );
          })}
        </div>
      </div>
    </div>
  )}
</section>

<style>
  .about-section {
    padding-top: 2.5rem;
  }

  /* Default layout: avatar left, [summary + links] right */
  .about-content {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .about-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border);
    flex-shrink: 0;
  }

  .about-text {
    flex: 1;
  }

  .about-summary {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    white-space: pre-line;
    margin-bottom: 1rem;
  }

  .about-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .about-contact-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .about-contact-item:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* Engineer layout: [avatar + links] top row, summary below */
  .about-content--engineer {
    flex-direction: column;
    gap: 1rem;
  }

  .about-top {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .about-content--engineer .about-meta {
    flex-direction: column;
    gap: 0.4rem;
    justify-content: center;
  }

  .about-content--engineer .about-summary {
    margin-bottom: 0;
  }
</style>
