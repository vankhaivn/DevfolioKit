---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import About from '@/components/sections/About.astro';
import Experience from '@/components/sections/Experience.astro';
import Projects from '@/components/sections/Projects.astro';
import Skills from '@/components/sections/Skills.astro';
import Education from '@/components/sections/Education.astro';
import Contact from '@/components/sections/Contact.astro';
import type { Config } from '@/lib/schema.js';

interface Props {
  config: Config;
}

const { config } = Astro.props;

const sections = config.settings.sections ?? [
  'about', 'experience', 'projects', 'skills', 'education', 'certifications', 'contact',
];

const showSection = (name: string) => sections.includes(name);
---

<BaseLayout config={config}>
  <div class="layout-engineer">
    <div class="container-wide">
      <Header config={config} />

      <main id="main-content" class="engineer-grid">
        <!-- Sidebar -->
        <aside class="engineer-sidebar">
          {showSection('about') && <About config={config} />}
          {showSection('skills') && config.skills && config.skills.length > 0 && (
            <Skills skills={config.skills} />
          )}
          {(showSection('education') || showSection('certifications')) && (
            <Education
              education={showSection('education') ? config.education : []}
              certifications={showSection('certifications') ? config.certifications : []}
            />
          )}
          {showSection('contact') && <Contact config={config} />}
        </aside>

        <!-- Main content -->
        <div class="engineer-main">
          {showSection('projects') && config.projects && config.projects.length > 0 && (
            <Projects projects={config.projects} variant="grid" />
          )}
          {showSection('experience') && config.experience && config.experience.length > 0 && (
            <Experience experience={config.experience} />
          )}
        </div>
      </main>

      <footer class="site-footer">
        <a href="https://github.com/vankhaivn/DevfolioKit" target="_blank" rel="noopener noreferrer" class="footer-brand">
          <img src="/favicon.svg" alt="DevfolioKit logo" class="footer-logo" />
          <span class="footer-name">DevfolioKit</span>
        </a>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .layout-engineer {
    min-height: 100dvh;
    padding-bottom: 4rem;
  }

  .engineer-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0 3rem;
    align-items: start;
    margin-top: 0.5rem;
  }

  .engineer-sidebar {
    position: sticky;
    top: 1.5rem;
  }

  .engineer-sidebar .section {
    padding-block: 2rem;
  }

  .engineer-main .section {
    padding-block: 2.5rem;
  }

  @media (max-width: 768px) {
    .engineer-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .engineer-sidebar {
      position: static;
    }
  }

  .site-footer {
    padding-top: 3rem;
    padding-bottom: 1rem;
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .footer-brand:hover {
    opacity: 1;
  }

  .footer-logo {
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    display: block;
  }

  .footer-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
</style>
